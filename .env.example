# =====================================================
# AGROSHOP — Variables de entorno (VPS Producción)
# Copiar como .env y rellenar los valores
# =====================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # Contraseña segura para la BD
POSTGRES_DB=AgroShop

# --- NextAuth ---
NEXTAUTH_URL=https://tu-dominio.com   # URL pública del sitio
NEXTAUTH_SECRET=                      # Generar con: openssl rand -base64 32

# --- App ---
NEXT_PUBLIC_APP_NAME=AgroShop SENA
NEXT_PUBLIC_IVA_PERCENTAGE=10
NEXT_PUBLIC_STOCK_BAJO_UMBRAL=10
NEXT_PUBLIC_DIAS_ALERTA_VENCIMIENTO=7

# --- Email (opcional) ---
RESEND_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
