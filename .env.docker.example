# =====================================================
# AGROSHOP - VARIABLES DE ENTORNO PARA DOCKER
# Copia este archivo a .env y ajusta los valores
# =====================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=AgroShop

# NextAuth (IMPORTANTE: cambiar en producción)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=AgroShop2025SecretKeyParaSENACentroAgropecuario123456789

# Configuración de la Aplicación
NEXT_PUBLIC_APP_NAME=AgroShop SENA
NEXT_PUBLIC_IVA_PERCENTAGE=10
NEXT_PUBLIC_STOCK_BAJO_UMBRAL=10
NEXT_PUBLIC_DIAS_ALERTA_VENCIMIENTO=7

# Email (opcional)
RESEND_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
