# =====================================================
# AGROSHOP - VARIABLES DE ENTORNO PARA DOCKER
# Copia este archivo a .env y ajusta los valores
# =====================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=AgroShop

# NextAuth (IMPORTANTE: cambiar en producción)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Configuración de la Aplicación
NEXT_PUBLIC_APP_NAME=AgroShop SENA
NEXT_PUBLIC_IVA_PERCENTAGE=10
NEXT_PUBLIC_STOCK_BAJO_UMBRAL=10
NEXT_PUBLIC_DIAS_ALERTA_VENCIMIENTO=7

# Email (opcional)
RESEND_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Redis (rate limiting distribuido)
REDIS_URL=redis://redis:6379

# Rate limiting (P1)
RATE_LIMIT_VENTAS_POST_MAX=15
RATE_LIMIT_VENTAS_POST_WINDOW_MS=60000
RATE_LIMIT_RETIROS_POST_MAX=10
RATE_LIMIT_RETIROS_POST_WINDOW_MS=60000
RATE_LIMIT_MOVIMIENTOS_POST_MAX=10
RATE_LIMIT_MOVIMIENTOS_POST_WINDOW_MS=60000
RATE_LIMIT_TURNOS_POST_MAX=5
RATE_LIMIT_TURNOS_POST_WINDOW_MS=60000
